{
	"compilerOptions": {
		"target": "ESNext",
		"lib": ["DOM", "DOM.Iterable", "ES2022"],
		"jsx": "preserve",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"noEmit": true,
		"incremental": true,
		"plugins": [{ "name": "next" }],
		"paths": {
			"@/*": ["./*"]
		},
		"allowJs": true,
		"isolatedModules": true
	},
	"include": [
		"next-env.d.ts",
		"app/**/*.ts",
		"app/**/*.tsx",
		"components/**/*.ts",
		"components/**/*.tsx",
		"lib/**/*.ts",
		"prismicio.ts",
		"slices/**/*.ts",
		"slices/**/*.tsx",
		"scripts/**/*",
		"prismicio-types.d.ts",
		"slicemachine.config.json",
		".next/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
